# EC2 Environment Configuration
# Copy this to .env and fill in your EC2 IP address

# EC2 Host
EC2_HOST=your-ec2-ip-or-domain

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_BROKERS=kafka:9092

# PostgreSQL Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres_password_change_me
DB_NAME=orderflow_db

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Security
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production

# Service Ports (internal to Docker network)
API_GATEWAY_PORT=8080
ORDER_SERVICE_PORT=8081
INVENTORY_SERVICE_PORT=8082
PAYMENT_SERVICE_PORT=8083
NOTIFICATION_SERVICE_PORT=8084
SHIPPING_SERVICE_PORT=8085
ANALYTICS_SERVICE_PORT=8086

# Email Configuration (optional, for real notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# Delivery Simulation
DELIVERY_DELAY_SECONDS=30

# Application Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
